<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp">

        <!-- Hotel Image on the left -->
        <ImageView
            android:id="@+id/ivHotelItemImage"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:scaleType="centerCrop"
            android:background="#CCCCCC"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <!-- Hotel Name -->
        <TextView
            android:id="@+id/tvHotelItemName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Hotel Name"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/ivHotelItemImage"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Location -->
        <TextView
            android:id="@+id/tvHotelItemLocation"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Location"
            android:textSize="12sp"
            android:textColor="#666666"
            android:layout_marginStart="8dp"
            android:layout_marginTop="2dp"
            app:layout_constraintTop_toBottomOf="@id/tvHotelItemName"
            app:layout_constraintStart_toEndOf="@id/ivHotelItemImage"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Star Rating -->
        <RatingBar
            style="@style/Widget.AppCompat.RatingBar.Small"
            android:id="@+id/rbHotelItemRating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:numStars="5"
            android:stepSize="0.5"
            android:isIndicator="true"
            android:layout_marginStart="8dp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvHotelItemLocation"
            app:layout_constraintStart_toEndOf="@id/ivHotelItemImage"/>

        <!-- Amenities -->
        <TextView
            android:id="@+id/tvHotelItemAmenities"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Free WiFi · Pool"
            android:textSize="11sp"
            android:textColor="#1A4A7A"
            android:layout_marginStart="8dp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/rbHotelItemRating"
            app:layout_constraintStart_toEndOf="@id/ivHotelItemImage"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Price per night -->
        <TextView
            android:id="@+id/tvHotelItemPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$80/night"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#E8604C"
            android:layout_marginStart="8dp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvHotelItemAmenities"
            app:layout_constraintStart_toEndOf="@id/ivHotelItemImage"/>

        <!-- Total price -->
        <TextView
            android:id="@+id/tvHotelItemTotal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="$240 total"
            android:textSize="11sp"
            android:textColor="#999999"
            android:layout_marginStart="8dp"
            android:layout_marginTop="2dp"
            app:layout_constraintTop_toBottomOf="@id/tvHotelItemPrice"
            app:layout_constraintStart_toEndOf="@id/ivHotelItemImage"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Book Now Button -->
        <Button
            android:id="@+id/btnHotelItemBook"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Book Now"
            android:textSize="12sp"
            android:backgroundTint="#0a850e"
            android:layout_marginStart="8dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvHotelItemTotal"
            app:layout_constraintStart_toEndOf="@id/ivHotelItemImage"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>